# ╔═╡ e0caca92-2f65-46fc-8ea1-a4285ec61c20
md"""
We first define the functions needed to generate random pure and mixed density matrices.
"""

# ╔═╡ f7ef1ed8-fb2b-4d6a-8e80-f268a0345bb5
begin
	#Function to generate pure state density matrices
	
	function rhopure(n)
		psi=rand(Float64,n)
		psi=psi/norm(psi)
		rho=psi*psi'
		return rho
	end

	function rhomixed(n)
		r1=rhopure(n)
		r2=rhopure(n)
		p=rand(Float64)
		rho=p*r1+(1-p)*r2
		return rho
	end 
	
end

# ╔═╡ 6f83ccc8-d70b-4db5-b327-9cd706fe236b
